#  secrets.toml real (ele está no .gitignore).
#
#  EM PRODUÇÃO (Streamlit Community Cloud):
#    Não suba nenhum secrets.toml. Vá em:
#       Manage app  ->  Settings  ->  Secrets
#    e cole o conteúdo abaixo (com seus hashes reais) na caixa de texto.
#
#  PARA TESTE LOCAL com st.secrets:
#    Copie este arquivo para  .streamlit/secrets.toml  e preencha.
# ============================================================================

# Mesma string do AUTH_USERS descrita no .env.example:
#   usuario:perfil:hash_sha256   (varios separados por ;)
# Gerar hash:
#   python -c "import hashlib; print(hashlib.sha256('SENHA'.encode()).hexdigest())"

AUTH_USERS = "admin:admin:COLE_O_HASH_REAL;consulta:visualizador:COLE_O_HASH_REAL"
