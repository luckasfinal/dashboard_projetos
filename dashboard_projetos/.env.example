# ============================================================================
#  .env.example  —  MODELO de variáveis de ambiente (uso LOCAL)
# ============================================================================
#  COPIE este arquivo para ".env" e preencha com valores reais.
#  O arquivo ".env" está no .gitignore e NUNCA deve ser enviado ao GitHub.
#
#  Em PRODUÇÃO (Streamlit Community Cloud) NÃO se usa .env: as credenciais
#  vão no painel "Secrets" do app (ver instruções de deploy). O formato do
#  valor (AUTH_USERS) é exatamente o mesmo mostrado abaixo.
# ============================================================================

# ----------------------------------------------------------------------------
# AUTH_USERS — lista de usuários permitidos.
#
# Formato de cada usuário:   usuario:perfil:hash_sha256_da_senha
# Vários usuários separados por ponto e vírgula ( ; ), tudo em UMA linha.
#
# Perfis válidos:
#     admin         -> acesso total (edição, upload, exclusão)
#     visualizador  -> somente leitura
#
# >>> COMO GERAR O HASH de uma senha (rode no terminal) <<<
#     python -c "import hashlib; print(hashlib.sha256('MinhaSenhaForte'.encode()).hexdigest())"
#
# Cole o hash gerado no lugar do hash de exemplo. Os valores abaixo são
# PLACEHOLDERS — substitua usuários, perfis e hashes pelos seus.
# ----------------------------------------------------------------------------
AUTH_USERS="admin:admin:COLE_AQUI_O_HASH_DA_SENHA_DO_ADMIN;consulta:visualizador:COLE_AQUI_O_HASH_DA_SENHA_DO_CONSULTA"
